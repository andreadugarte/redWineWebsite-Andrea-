# ─────────────────────────────────────────────────────────────
# Red del Vino — environment variables
# Copy to .env.local for local dev. Add these in Vercel → Settings → Environment Variables.
# EVERYTHING IS OPTIONAL: the site runs fully (with a SIMULATED checkout and
# form-inquiry fallbacks) even with none of these set.
# ─────────────────────────────────────────────────────────────

# --- Payments (optional) — Stripe. If unset, checkout is SIMULATED (order confirmed, no charge). ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email (optional) — Resend, for reservation / contact / newsletter forms. ---
# If unset, forms fall back to a success stub (submission logged server-side, no email sent).
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@reddelvino.com
RESERVATIONS_TO_EMAIL=reservas@reddelvino.com

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://reddelvino.com
